# ─────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────
# Supabase Transaction mode pooler (port 6543) — Prisma runtime queries
# Get from: Supabase Dashboard → Project Settings → Database → Connection string → Transaction
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Supabase Session mode (port 5432) — Prisma Migrate (DDL statements require direct connection)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string → Session
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# ─────────────────────────────────────────────────
# NEXTAUTH / AUTH.JS v5
# ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Get from https://dashboard.stripe.com/webhooks after registering:
# Endpoint: https://yourdomain.com/api/webhooks/stripe
# Events to subscribe:
#   checkout.session.completed
#   checkout.session.expired
#   payment_intent.payment_failed
#   customer.subscription.updated
#   customer.subscription.deleted
#   account.updated
STRIPE_WEBHOOK_SECRET="whsec_..."

# Subscription tier price IDs — create recurring prices in your Stripe dashboard
# Products: Starter ($9/mo), Pro ($29/mo), Prime ($49/mo), Label ($199/mo)
STRIPE_PRICE_ID_STARTER="price_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_PRIME="price_..."
STRIPE_PRICE_ID_LABEL="price_..."

# ─────────────────────────────────────────────────
# OPENAI (AI scoring, recommendations, chat)
# ─────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
# If not set, AI features degrade gracefully
OPENAI_API_KEY="sk-..."

# ─────────────────────────────────────────────────
# REDIS (caching + BullMQ background jobs)
# ─────────────────────────────────────────────────
# Upstash Redis (recommended for Vercel): https://upstash.com
# Or any ioredis-compatible URL: redis://user:pass@host:6379
# If not set, caching and background jobs are disabled gracefully
REDIS_URL="rediss://default:TOKEN@hostname:6380"

# ─────────────────────────────────────────────────
# SUPABASE (Realtime subscriptions + File Storage)
# ─────────────────────────────────────────────────
# Auth and DB are handled by NextAuth + Prisma.
# Supabase is used for browser-side Realtime channels AND server-side file storage.
# If not set, real-time and file upload features are disabled (everything else works normally).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Service role key — used server-side ONLY for Storage operations (never expose to browser)
# Get from Supabase project settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─────────────────────────────────────────────────
# CRON JOBS (Vercel Cron security)
# ─────────────────────────────────────────────────
# Used to authenticate /api/cron/* endpoints called by Vercel Crons.
# Generate with: openssl rand -base64 32
# Add the same value to Vercel project env vars AND vercel.json cron headers.
CRON_SECRET="your-cron-secret-here"

# ─────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────
# Canonical public URL used across the app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Legacy fallback for older codepaths and scripts
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SITE_URL="http://localhost:3000"
