# ─────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────
# PostgreSQL connection string (e.g. from Supabase, Neon, Railway, or local Docker)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/epic_music_space?schema=public"

# ─────────────────────────────────────────────────
# NEXTAUTH / AUTH.JS v5
# ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Get from https://dashboard.stripe.com/webhooks after registering:
# Endpoint: https://yourdomain.com/api/webhooks/stripe
# Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────────────
# OPENAI (Phase 2 — AI features)
# ─────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
# If not set, AI features degrade gracefully
OPENAI_API_KEY="sk-..."

# ─────────────────────────────────────────────────
# SUPABASE (Phase 2 — Realtime subscriptions only)
# ─────────────────────────────────────────────────
# Auth and DB are handled by NextAuth + Prisma.
# Supabase is used ONLY for browser-side Realtime channels.
# If not set, real-time features are disabled (everything else works normally).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

