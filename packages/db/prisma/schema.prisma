// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTH / USERS
// ─────────────────────────────────────────

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  name                 String?
  username             String?  @unique
  image                String?
  passwordHash         String?
  role                 Role     @default(LISTENER)
  emailVerified        DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Stripe Connect for artist payouts
  stripeConnectId      String?  @unique

  // NextAuth relations
  accounts             Account[]
  sessions             Session[]

  // Platform relations
  songs                Song[]
  licenses             LicenseToken[]
  transactions         Transaction[]
  payouts              Payout[]

  // Phase 2 relations
  studio               Studio?
  ownedLabel           Label?      @relation("LabelOwner")
  labelMemberships     LabelArtist[] @relation("LabelArtistUser")
  adPlacements         AdPlacement[]
  notifications        Notification[]
  versusVotes          VersusVote[]
  following            UserFollow[] @relation("Follower")
  followers            UserFollow[] @relation("Following")

  // Phase 2: invite engine
  inviteCodesCreated   InviteCode[] @relation("InviteCreator")
  inviteCodeUsed       InviteCode?  @relation("InviteUsed")

  // Phase 2: badges
  badges               UserBadge[]

  // Auctions & tips
  auctionsCreated      Auction[]    @relation("AuctionSeller")
  auctionsWon          Auction[]    @relation("AuctionWinner")
  auctionBids          AuctionBid[] @relation("AuctionBidder")
}

enum Role {
  LISTENER   // can purchase licenses
  ARTIST     // can upload songs + earn royalties
  LABEL      // can run a label and sign artists
  ADMIN      // platform admin
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// MUSIC CATALOG
// ─────────────────────────────────────────

model Song {
  id                String   @id @default(cuid())
  title             String
  artist            String
  genre             String?
  description       String?  @db.Text
  audioUrl          String
  coverUrl          String?
  bpm               Int?
  key               String?

  // Licensing economics
  licensePrice      Decimal  @db.Decimal(10, 2)
  revenueSharePct   Decimal  @db.Decimal(5, 2)
  totalLicenses     Int      @default(100)
  soldLicenses      Int      @default(0)
  isActive          Boolean  @default(true)

  // Phase 2: scoring & discovery
  aiScore           Float    @default(0)   // composite popularity/quality score
  boostScore        Float    @default(0)   // additional visibility from paid boost packages
  versusWins        Int      @default(0)
  versusLosses      Int      @default(0)
  streamCount       Int      @default(0)
  district          District @default(INDIE_BLOCKS)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  artistId          String
  artist_           User     @relation(fields: [artistId], references: [id], onDelete: Cascade)

  licenses          LicenseToken[]
  transactions      Transaction[]
  payouts           Payout[]
  versusMatchesA    VersusMatch[] @relation("VersusA")
  versusMatchesB    VersusMatch[] @relation("VersusB")
  auctions          Auction[]

  @@index([artistId])
  @@index([district])
  @@index([isActive])
  @@index([aiScore])
}

// ─────────────────────────────────────────
// LICENSING
// ─────────────────────────────────────────

model LicenseToken {
  id              String          @id @default(cuid())
  tokenNumber     Int                               // e.g. license #42 of 100
  status          LicenseStatus   @default(ACTIVE)
  purchasedAt     DateTime        @default(now())
  price           Decimal         @db.Decimal(10, 2)

  songId          String
  song            Song            @relation(fields: [songId], references: [id], onDelete: Cascade)

  holderId        String
  holder          User            @relation(fields: [holderId], references: [id], onDelete: Cascade)

  transactions    Transaction[]
  payouts         Payout[]

  @@unique([songId, tokenNumber])
}

enum LicenseStatus {
  ACTIVE      // license is valid and earning revenue share
  EXPIRED     // license term ended
  REVOKED     // artist/admin revoked
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Transaction {
  id                  String            @id @default(cuid())
  amount              Decimal           @db.Decimal(10, 2)
  currency            String            @default("usd")
  type                TransactionType
  status              PaymentStatus     @default(PENDING)

  stripePaymentIntentId String?         @unique
  stripeSessionId       String?         @unique
  metadata              Json?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  songId              String?
  song                Song?             @relation(fields: [songId], references: [id])

  licenseTokenId      String?
  licenseToken        LicenseToken?     @relation(fields: [licenseTokenId], references: [id])

  @@index([userId])
  @@index([status])
}

enum TransactionType {
  LICENSE_PURCHASE    // buyer acquires a license for a song
  REVENUE_PAYOUT      // platform pays artist/holder their revenue share
  SUBSCRIPTION        // platform subscription tier
  BOOST               // paid visibility boost
  TIP                 // fan tips an artist directly
  AUCTION_WIN         // buyer wins a license auction
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────
// REVENUE DISTRIBUTION
// ─────────────────────────────────────────

model Payout {
  id             String       @id @default(cuid())
  amount         Decimal      @db.Decimal(10, 2)
  currency       String       @default("usd")
  period         String       // e.g. "2024-Q1"
  status         PayoutStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  songId         String
  song           Song         @relation(fields: [songId], references: [id])

  licenseTokenId String?
  licenseToken   LicenseToken? @relation(fields: [licenseTokenId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([period])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ─────────────────────────────────────────
// PHASE 2: DISTRICTS
// ─────────────────────────────────────────

enum District {
  INDIE_BLOCKS    // default — general discovery
  DOWNTOWN_PRIME  // high-visibility placement (unlocked by performance)
  LABEL_ROW       // elite — label-backed artists only
}

// ─────────────────────────────────────────
// PHASE 2: ARTIST STUDIO
// ─────────────────────────────────────────

model Studio {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username    String   @unique
  bio         String?  @db.Text
  district    District @default(INDIE_BLOCKS)
  level       Int      @default(1)
  bannerUrl   String?
  socialLinks Json?    // { twitter, instagram, spotify, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────
// PHASE 2: VERSUS (SONG BATTLE)
// ─────────────────────────────────────────

model VersusMatch {
  id        String       @id @default(cuid())
  songAId   String
  songBId   String
  songA     Song         @relation("VersusA", fields: [songAId], references: [id], onDelete: Cascade)
  songB     Song         @relation("VersusB", fields: [songBId], references: [id], onDelete: Cascade)
  votesA    Int          @default(0)
  votesB    Int          @default(0)
  status    VersusStatus @default(ACTIVE)
  endsAt    DateTime
  createdAt DateTime     @default(now())

  votes     VersusVote[]

  @@index([status])
  @@index([endsAt])
}

enum VersusStatus {
  ACTIVE
  COMPLETED
}

model VersusVote {
  id           String      @id @default(cuid())
  matchId      String
  match        VersusMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  votedSongId  String      // the songId they voted for

  createdAt    DateTime    @default(now())

  @@unique([matchId, userId])
}

// ─────────────────────────────────────────
// PHASE 2: LABEL SYSTEM
// ─────────────────────────────────────────

model Label {
  id           String        @id @default(cuid())
  name         String        @unique
  slug         String        @unique
  ownerId      String        @unique
  owner        User          @relation("LabelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  logoUrl      String?
  bio          String?       @db.Text
  revSharePct  Decimal       @db.Decimal(5, 2) @default(10) // label's cut of signed artist earnings
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  artists      LabelArtist[]
}

model LabelArtist {
  id           String            @id @default(cuid())
  labelId      String
  label        Label             @relation(fields: [labelId], references: [id], onDelete: Cascade)
  artistId     String
  artist       User              @relation("LabelArtistUser", fields: [artistId], references: [id], onDelete: Cascade)
  revSharePct  Decimal           @db.Decimal(5, 2)  // label's cut of THIS artist's earnings
  status       LabelArtistStatus @default(PENDING)
  createdAt    DateTime          @default(now())

  @@unique([labelId, artistId])
}

enum LabelArtistStatus {
  PENDING     // offer sent, not yet accepted
  ACTIVE      // artist is signed
  TERMINATED  // contract ended
}

// ─────────────────────────────────────────
// PHASE 2: AD PLACEMENTS
// ─────────────────────────────────────────

model AdPlacement {
  id          String     @id @default(cuid())
  location    AdLocation
  title       String
  mediaUrl    String
  linkUrl     String?
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  price       Decimal    @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
}

enum AdLocation {
  MARKETPLACE_BANNER
  STUDIO_SIDEBAR
  CITY_BILLBOARD
  VERSUS_BANNER
}

// ─────────────────────────────────────────
// PHASE 2: NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "LICENSE_SOLD", "VERSUS_RESULT", "LABEL_OFFER", "PAYOUT", etc.
  title     String
  body      String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// ─────────────────────────────────────────
// PHASE 2: SOCIAL FOLLOWS
// ─────────────────────────────────────────

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

// ─────────────────────────────────────────
// PHASE 2: INVITE ENGINE
// ─────────────────────────────────────────

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdAt   DateTime  @default(now())
  usedAt      DateTime?

  createdById String
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  usedById    String?   @unique
  usedBy      User?     @relation("InviteUsed", fields: [usedById], references: [id])
}

// ─────────────────────────────────────────
// PHASE 2: BADGES + PRESTIGE
// ─────────────────────────────────────────

model UserBadge {
  id        String    @id @default(cuid())
  type      BadgeType
  awardedAt DateTime  @default(now())

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum BadgeType {
  EARLY_ADOPTER       // first 1 000 users to join
  INVITE_5            // invited 5 friends
  INVITE_10           // invited 10 friends
  INVITE_50           // invited 50 friends
  FIRST_BATTLE_WIN    // won a versus battle
  FIRST_LICENSE_SOLD  // sold first license (artist)
  LICENSE_HOLDER      // purchased first license (fan)
  TOP_ARTIST          // reached #1 on leaderboard
}

// ─────────────────────────────────────────
// AUCTIONS
// ─────────────────────────────────────────

model Auction {
  id            String        @id @default(cuid())
  songId        String
  song          Song          @relation(fields: [songId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        User          @relation("AuctionSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  startingBid   Decimal       @db.Decimal(10, 2)
  reservePrice  Decimal?      @db.Decimal(10, 2)
  currentBid    Decimal?      @db.Decimal(10, 2)

  winnerId      String?
  winner        User?         @relation("AuctionWinner", fields: [winnerId], references: [id])

  status        AuctionStatus @default(ACTIVE)
  endsAt        DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  bids          AuctionBid[]

  @@index([status, endsAt])
  @@index([songId])
  @@index([sellerId])
}

enum AuctionStatus {
  ACTIVE
  ENDED
  SETTLED
  EXPIRED
  CANCELLED
}

model AuctionBid {
  id        String   @id @default(cuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId  String
  bidder    User     @relation("AuctionBidder", fields: [bidderId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([auctionId, amount(sort: Desc)])
  @@index([bidderId])
}

