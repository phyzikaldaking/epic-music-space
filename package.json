{
  "name": "epic-music-space",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:web && npm --workspace apps/api run build",
    "build:turbo": "turbo run build",
    "build:web": "npm run clean:web && npm --workspace packages/db run db:generate && npm --workspace apps/web run build",
    "clean:web": "rm -rf apps/web/.next",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:deploy": "npm --workspace packages/db run db:deploy",
    "db:seed": "npm --workspace packages/db run db:seed",
    "db:studio": "cd packages/db && npx prisma studio",
    "vercel:build": "npm run build:web"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
