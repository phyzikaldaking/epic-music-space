{
  "name": "epic-music-space",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "npm --workspace packages/db run db:seed",
    "db:studio": "cd packages/db && npx prisma studio",
    "vercel:env:check": "node scripts/vercel-env-push.mjs production --dry-run",
    "vercel:env:push": "node scripts/vercel-env-push.mjs production"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
